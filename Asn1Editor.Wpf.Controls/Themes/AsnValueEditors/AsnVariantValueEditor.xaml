<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:c="clr-namespace:SysadminsLV.Asn1Editor.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AsnValueEditorResources.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="c:AsnVariantValueEditor">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="c:AsnVariantValueEditor">
                    <TextBox Style="{StaticResource AsnValueEditorLargeTextBoxStyle}"
                             Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, UpdateSourceTrigger=PropertyChanged}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>