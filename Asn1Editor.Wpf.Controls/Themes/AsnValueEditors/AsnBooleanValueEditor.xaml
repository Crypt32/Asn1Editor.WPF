<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:SysadminsLV.WPF.OfficeTheme.Toolkit.Behaviors;assembly=Wpf.OfficeTheme"
                    xmlns:c="clr-namespace:SysadminsLV.Asn1Editor.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AsnValueEditor.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="c:AsnBooleanValueEditor" BasedOn="{StaticResource {x:Type c:AsnValueEditor}}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="c:AsnBooleanValueEditor">
                    <StackPanel behaviors:MarginSetter.Margin="3"
                                VerticalAlignment="Center">
                        <CheckBox x:Name="MainCheck"
                                  IsThreeState="False"
                                  Content="False"
                                  IsChecked="{Binding Value, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <TextBlock>
                            <Run Text="Hex value:"/>
                            <Run x:Name="HexValue" Text="0x0"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Numeric value:"/>
                            <Run x:Name="NumericValue" Text="0"/>
                        </TextBlock>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="MainCheck" Property="IsChecked" Value="True">
                            <Setter TargetName="MainCheck" Property="Content" Value="True"/>
                            <Setter TargetName="HexValue" Property="Text" Value="0xFF"/>
                            <Setter TargetName="NumericValue" Property="Text" Value="255"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>