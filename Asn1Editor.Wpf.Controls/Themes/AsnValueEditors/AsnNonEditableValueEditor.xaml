<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:SysadminsLV.Asn1Editor.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AsnValueEditor.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    <Style TargetType="c:AsnNonEditableValueEditor" BasedOn="{StaticResource {x:Type c:AsnValueEditor}}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="c:AsnNonEditableValueEditor">
                    <TextBox Style="{StaticResource AsnValueEditorLargeTextBoxStyle}"
                             Foreground="{StaticResource TabItem.FgBrush}"
                             Background="Transparent"
                             Text="Containers and NULL (0x05) tags are not editable"
                             IsReadOnly="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>